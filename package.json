{
  "name": "erli-rest-client-ts",
  "version": "0.1.0",
  "description": "Typed, server-side TypeScript client for the ERLI marketplace Shop API.",
  "keywords": [
    "erli",
    "marketplace",
    "api",
    "typescript",
    "nodejs",
    "ecommerce"
  ],
  "homepage": "https://github.com/CichockiAdrian/erli-rest-client-ts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CichockiAdrian/erli-rest-client-ts.git"
  },
  "bugs": {
    "url": "https://github.com/CichockiAdrian/erli-rest-client-ts/issues"
  },
  "license": "MIT",
  "author": "Adrian Cichocki",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm test && npm run build",
    "prepare": "npm run build",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
